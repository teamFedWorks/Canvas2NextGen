# LMS Ingestion Service Configuration

# Security
# Required for API access. Example: 'your-secure-api-key'
LMS_API_KEY=your-secure-api-key
# NOTE: DISABLE_AUTH has been permanently removed. Authentication is always enforced.

# AWS Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3 Configuration
S3_INGESTION_BUCKET=eduvatehub-courseshells-prod
S3_CDN_BUCKET=lms-course-assets
CDN_URL=https://cdn.example.com

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=lms_db

# File Limits
MAX_UPLOAD_MB=500
MAX_EXTRACTED_GB=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Institution Scoping ────────────────────────────────────────────────────────
# Default institution used when --uni / --author are not passed on the CLI.
# For multi-institution deployments, pass --uni and --author explicitly or
# set institution-specific variables and reference them in your scripts.

# SFC (St. Francis College) — primary institution
DEFAULT_UNIVERSITY_ID=
DEFAULT_AUTHOR_ID=

# WBU — second institution
# Pass these via --uni / --author when running:
#   python cli.py ingest-s3 --institution WBU --uni $WBU_UNIVERSITY_ID --author $WBU_AUTHOR_ID
WBU_UNIVERSITY_ID=
WBU_AUTHOR_ID=

# DynamoDB (used by the /migrate/hierarchical API endpoint)
DYNAMODB_METADATA_TABLE=CourseMetadata

# Server
PORT=5009
